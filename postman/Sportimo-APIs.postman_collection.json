  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('run_id')) {",
          "  const runId = String(Date.now());",
          "  pm.collectionVariables.set('run_id', runId);",
          "  pm.collectionVariables.set('center_email', `center_${runId}@sportimo.test`);",
          "  pm.collectionVariables.set('athlete_email', `athlete_${runId}@sportimo.test`);",
          "}",
          "if (!pm.collectionVariables.get('center_password')) { pm.collectionVariables.set('center_password', 'CenterPass123!'); }",
          "if (!pm.collectionVariables.get('athlete_password')) { pm.collectionVariables.set('athlete_password', 'AthletePass123!'); }",
          "",
          "const now = new Date();",
          "const dow = now.getDay();",
          "let daysUntilMonday = (1 - dow + 7) % 7;",
          "if (daysUntilMonday === 0) daysUntilMonday = 7;",
          "const nextMonday = new Date(now.getTime() + daysUntilMonday * 24 * 60 * 60 * 1000);",
          "",
          "const yyyy = nextMonday.getFullYear();",
          "const mm = String(nextMonday.getMonth() + 1).padStart(2, '0');",
          "const dd = String(nextMonday.getDate()).padStart(2, '0');",
          "const dateStr = `${yyyy}-${mm}-${dd}`;",
          "",
          "pm.collectionVariables.set('available_slots_date', dateStr);",
          "pm.collectionVariables.set('booking_start', `${dateStr}T09:00:00`);",
          "pm.collectionVariables.set('booking_end', `${dateStr}T10:00:00`);"
        ]
      }
    }
  ],
